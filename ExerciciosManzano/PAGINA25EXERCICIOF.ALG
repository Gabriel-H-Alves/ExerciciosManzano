Algoritmo "Pagina25exercicioF"
// Disciplina : Lógica de Programaçăo
// Professor  : Jailson Costa dos Santos
// Descriçăo  : Trocar os valores
// Autor(a)   : Gabriel Henrique Alves Rocha 
// Data atual : 05/04/2026

Var
// Seçăo de Declaraçőes das variáveis 
valor1, valor2, valor3: inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
 escreval("Valor a ser armazenado em A: ")
   leia(valor1)

   escreval("Valor a ser armazenado em B: ")
   leia(valor2)

   valor3 <- valor1
   valor1 <- valor2
   valor2 <- valor3


   escreval("Valor em A: ", valor1)
   escreva("Valor em B: ", valor2)
Fimalgoritmo