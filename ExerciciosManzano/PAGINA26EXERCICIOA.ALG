Algoritmo "ProgramaDeComputador"
// Disciplina : Lógica de Programaçăo
// Professor  : Jailson Costa dos Santos
// Descriçăo  : Programa de computador
// Autor(a)   : Gabriel Henrique Alves Rocha 
// Data atual : 05/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
a, b, c, d, produto, soma: inteiro
Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
 escreva("Digite o valor de A: ")
   leia(a)

   escreva("Digite o valor de B: ")
   leia(b)

   escreva("Digite o valor de C: ")
   leia(c)

   escreva("Digite o valor de D: ")
   leia(d)

   produto <- a*c
   soma<- b+d


   escreval("Produto de A e C : ", produto)
   escreval("Soma de B e D : ", soma)

Fimalgoritmo