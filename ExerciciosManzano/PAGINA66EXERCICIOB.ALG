Algoritmo "Pagina66exercicioB"
// Disciplina : Lógica de Programaçăo
// Professor  : Jailson Costa dos Santos
// Descriçăo  : Tabuada
// Autor(a)   : Gabriel Henrique Alves Rocha 
// Data atual : 06/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
 i, numero : inteiro

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
  escreva("Digite o número: ")
   leia(numero)

   escreval("Tabuáda do ", numero)

   para i de 0 ate 10 passo 1 faca
      escreval(numero, " x ", i, " = ", numero*i)
      i<- i+1
   fimpara

Fimalgoritmo