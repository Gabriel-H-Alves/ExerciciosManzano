Algoritmo " SomaEMedia"
// Disciplina : Lógica de Programaçăo
// Professor  : Jailson Costa dos Santos
// Descriçăo  : Soma e media dos numero entre 50 e 70
// Autor(a)   : Gabriel Henrique Alves Rocha 
// Data atual : 06/04/2026
Var
// Seçăo de Declaraçőes das variáveis 
numero, soma, q: inteiro
   media: real

Inicio
// Seçăo de Comandos, procedimento, funçőes, operadores, etc... 
  numero <- 50
   soma <- 0
   q <- 0

   enquanto (numero <= 70) faca
      se (numero % 2 = 0) entao
         soma <- soma + numero
         q <- q + 1
      fimse
      numero <- numero + 1
   fimenquanto

   media <- soma / q

   escreval("Soma dos pares de 50 a 70: ", soma)
   escreval("Média dos pares de 50 a 70: ", media)

Fimalgoritmo